# ============================================
# HOSPITAL WEBSITE - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values

# App Config
NEXT_PUBLIC_SITE_URL=https://yourhospital.com
NEXT_PUBLIC_SITE_NAME=Patil Multispeciality Hospital
NEXT_PUBLIC_PHONE=+91-9876543210
NEXT_PUBLIC_EMERGENCY_PHONE=+91-9876543211
NEXT_PUBLIC_EMAIL=info@yourhospital.com
NEXT_PUBLIC_ADDRESS=Patil Multispecility Hospital in Barshi Road, Latur
NEXT_PUBLIC_WHATSAPP=919876543210

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hospital?retryWrites=true&w=majority

# Email (Nodemailer / Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Patil Hospital <noreply@yourhospital.com>
ADMIN_EMAIL=admin@yourhospital.com

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://maps.google.com/maps?q=latur+hospital&output=embed

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# reCAPTCHA (optional)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
